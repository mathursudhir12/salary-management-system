# ── Frontend Environment Variables ────────────────────────────────────────────
#
# VITE_API_URL
#   The base URL of the backend API.
#   Leave empty in local development — Vite's dev server proxies /api/* to
#   http://localhost:5000 automatically (see vite.config.ts server.proxy).
#   Set this to your Render backend URL when deploying to Vercel.
#
# Example (production):
#   VITE_API_URL=https://your-backend.onrender.com

VITE_API_URL=
